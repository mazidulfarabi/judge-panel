# Copy to .env for local use only — never commit .env
# Netlify: set these under Site settings → Environment variables (not in the repo)

DATABASE_URL=postgresql://USER:PASSWORD@HOST:26257/defaultdb?sslmode=verify-full

PGSSLROOTCERT=

DB_CA_CERT=

JWT_SECRET=replace-with-long-random-string

ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-password

CASE_LINK=https://drive.google.com/file/d/119MYxnOduI2LWv5N4gAowNnpPSr6xnjy/view?usp=sharing

MARKING_INSTRUCTIONS=Please do accurate marking. Try to avoid leniency, strictness, or central tendency (all teams getting similar marks). Score each criterion independently based on the rubric.
